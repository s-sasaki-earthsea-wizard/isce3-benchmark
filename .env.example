# Copy to .env and adjust for your machine. .env is git-ignored.

# --- Host paths ---------------------------------------------------------------
# Absolute path to the isce3 source tree on the host. Mounted read-only into the
# container at /opt/isce3-src. The benchmark Dockerfile builds from this mount.
ISCE3_SRC=/mnt/nas/Projects/third-party-projects/isce3

# Where to place benchmark input data on the host. Mounted at /data.
BENCH_DATA_DIR=./data

# Where benchmark logs/profiles land on the host. Mounted at /logs.
# Convention: "logs_<hostname>" so multi-machine results don't collide.
# docker-compose env_file does NOT do shell expansion — use a literal value.
BENCH_LOG_DIR=./logs_local

# --- GPU ----------------------------------------------------------------------
# CUDA arch for compilation. RTX 5080 = Blackwell sm_120. Set "Auto" to detect.
ISCE_CUDA_ARCHS=120

# Device index visible to the container.
NVIDIA_VISIBLE_DEVICES=0

# --- Concurrency --------------------------------------------------------------
# CPU thread cap for OpenMP / TBB / numpy. Defaults to physical core count.
OMP_NUM_THREADS=16
MKL_NUM_THREADS=16

# --- Build cache --------------------------------------------------------------
# Persist isce3 build directory across container restarts.
ISCE3_BUILD_DIR=./isce3-build
