# Machine-dependent / large artifacts
data/*
!data/README.md
!data/.gitkeep

logs_*/
*.log
*.nsys-rep
*.qdrep
*.sqlite
*.csv
*.json
!reports/**/*.csv
!reports/**/*.json

# Local environment overrides
.env
*.local.sh

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Build artifacts (host-side; container uses /workspace)
build/
isce3-build/
isce3-install/

# Rendered S1 CSLC runconfigs (regenerated by `make render-s1` from templates).
# Templates and render tool are tracked; the rendered files contain a baked
# burst_id selection, so committing them would create churn on every regen.
configs/insar_s1_boso_cslc_cpu.yaml
configs/insar_s1_boso_cslc_gpu.yaml
configs/insar_s1_boso_cslc_sec_cpu.yaml
configs/insar_s1_boso_cslc_sec_gpu.yaml
